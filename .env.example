# Google Sheets Integration
# Copy this file to .env and fill in your values

# Your Google Spreadsheet ID (from the URL)
# Example: https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
REACT_APP_GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Your Google Cloud API Key (with Sheets API enabled)
REACT_APP_GOOGLE_API_KEY=your_api_key_here

# Your Google Apps Script Web App URL (for saving RSVP responses)
# Example: https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
REACT_APP_RSVP_ENDPOINT=your_apps_script_url_here
